<div class="p-6">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-800 dark:text-white">Feedbacks</h1>
    <button 
      (click)="openCreateModal()"
      class="bg-gradient-to-r from-emerald-400 to-teal-500 text-white px-4 py-2 rounded-lg hover:opacity-90 transition-opacity">
      + Add Feedback
    </button>
  </div>

  <!-- Loading State -->
  <div *ngIf="loading" class="text-center py-8">
    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-emerald-500 mx-auto"></div>
    <p class="mt-2 text-gray-600 dark:text-gray-400">Loading feedbacks...</p>
  </div>

  <!-- Feedbacks Table -->
  <div *ngIf="!loading" class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
      <thead class="bg-gray-50 dark:bg-gray-700">
        <tr>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">User ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Module ID</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Rating</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Comment</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-300 uppercase tracking-wider">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white dark:bg-gray-800 divide-y divide-gray-200 dark:divide-gray-700">
        <tr *ngFor="let feedback of feedbacks" class="hover:bg-gray-50 dark:hover:bg-gray-700">
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">{{ feedback.id }}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">{{ feedback.userId }}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">{{ feedback.moduleId }}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-yellow-500">{{ getStarRating(feedback.note) }}</td>
          <td class="px-6 py-4 text-sm text-gray-900 dark:text-white max-w-xs truncate">{{ feedback.commentaire }}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 dark:text-white">{{ feedback.date | date:'medium' }}</td>
          <td class="px-6 py-4 whitespace-nowrap text-sm">
            <button 
              (click)="openEditModal(feedback)"
              class="text-blue-600 hover:text-blue-900 dark:text-blue-400 dark:hover:text-blue-300 mr-3">
              Edit
            </button>
            <button 
              (click)="deleteFeedback(feedback.id!)"
              class="text-red-600 hover:text-red-900 dark:text-red-400 dark:hover:text-red-300">
              Delete
            </button>
          </td>
        </tr>
        <tr *ngIf="feedbacks.length === 0">
          <td colspan="7" class="px-6 py-8 text-center text-gray-500 dark:text-gray-400">
            No feedbacks found. Click "Add Feedback" to create one.
          </td>
        </tr>
      </tbody>
    </table>
  </div>

  <!-- Modal -->
  <div *ngIf="showModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
    <div class="bg-white dark:bg-gray-800 rounded-lg p-6 w-full max-w-md mx-4">
      <h2 class="text-xl font-bold mb-4 text-gray-800 dark:text-white">
        {{ editingFeedback ? 'Edit Feedback' : 'Add New Feedback' }}
      </h2>
      <form (ngSubmit)="saveFeedback()">
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">User ID</label>
          <input 
            type="number" 
            [(ngModel)]="editingFeedback ? editingFeedback.userId : newFeedback.userId" 
            name="userId"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white"
            required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Module ID</label>
          <input 
            type="number" 
            [(ngModel)]="editingFeedback ? editingFeedback.moduleId : newFeedback.moduleId" 
            name="moduleId"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white"
            required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Rating (1-5)</label>
          <input 
            type="number" 
            min="1" 
            max="5" 
            [(ngModel)]="editingFeedback ? editingFeedback.note : newFeedback.note" 
            name="note"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white"
            required>
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Comment</label>
          <textarea 
            [(ngModel)]="editingFeedback ? editingFeedback.commentaire : newFeedback.commentaire" 
            name="commentaire"
            rows="3"
            class="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg dark:bg-gray-700 dark:text-white"
            required></textarea>
        </div>
        <div class="flex justify-end gap-3">
          <button 
            type="button" 
            (click)="closeModal()"
            class="px-4 py-2 text-gray-700 dark:text-gray-300 hover:bg-gray-100 dark:hover:bg-gray-700 rounded-lg">
            Cancel
          </button>
          <button 
            type="submit"
            class="px-4 py-2 bg-emerald-500 text-white rounded-lg hover:bg-emerald-600">
            Save
          </button>
        </div>
      </form>
    </div>
  </div>
</div>
